{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flowcraft.local/schemas/import-model-v2.json",
  "title": "Import Model v2",
  "type": "object",
  "required": [
    "schemaVersion",
    "source",
    "clusters",
    "sections",
    "meta"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "import-model-v2"
    },
    "source": {
      "type": "object",
      "required": [
        "kind",
        "name"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "text",
            "document",
            "ai_assist"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "clusters": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "steps"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "clusterHint": {
            "type": "string"
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "kind",
                "title"
              ],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "process",
                    "decision",
                    "fact",
                    "policy",
                    "unclassified"
                  ]
                },
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "notes": {
                  "type": "string"
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "meta": {
      "type": "object",
      "required": [
        "warnings",
        "budgets"
      ],
      "properties": {
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "budgets": {
          "type": "object",
          "required": [
            "maxInputLines",
            "maxProcessNodes",
            "maxAnnotationNodes",
            "maxEdges"
          ],
          "properties": {
            "maxInputLines": {
              "type": "integer",
              "minimum": 1
            },
            "maxProcessNodes": {
              "type": "integer",
              "minimum": 1
            },
            "maxAnnotationNodes": {
              "type": "integer",
              "minimum": 0
            },
            "maxEdges": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
